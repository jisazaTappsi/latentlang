[Unit]
Description=LatentLang FastAPI (gunicorn)
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/latentlang
Environment="CORS_ORIGINS=https://www.latentlang.com"
ExecStart=/home/ubuntu/latentlang/.venv/bin/gunicorn backend.backend:app \
  -w 1 -k uvicorn.workers.UvicornWorker -b 127.0.0.1:9000 --timeout 120
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target